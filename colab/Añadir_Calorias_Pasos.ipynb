# Añadir fila de calorias y pasos por calorias
from google.colab import drive
import pandas as pd
import ast


# Montamos Drive en nuestro espacio de trabajo
drive.mount('/content/drive')

# Cargamos los datos en un Dataframe
data = pd.read_csv('/content/drive/MyDrive/DIET-IA/dataset/DATASET FINAL/RAW_recipes.csv')

# Visualizamos las primeras filas para verificar alérgenos e ingredientes
print(data.head())

# Convertir la columna nutrition (string → lista)
data["nutrition"] = data["nutrition"].apply(ast.literal_eval)

# Extraer calorías (posición 0)
data["calories"] = data["nutrition"].apply(lambda x: x[0])

# Calcular pasos equivalentes (1 paso ≈ 0.05 kcal)
data["steps_equivalent"] = data["calories"] / 0.05

# (Opcional) redondear pasos
data["steps_equivalent"] = data["steps_equivalent"].astype(int)

# (Opcional) calcular km caminados (1 paso ≈ 0.8 metros)
data["km_walk"] = data["steps_equivalent"] * 0.0008

# Ver resultado
print(data[["name", "calories", "steps_equivalent", "km_walk"]].head())

# Ruta donde quieres guardar el nuevo dataset
output_path = '/content/drive/MyDrive/DIET-IA/dataset/DATASET FINAL/RAW_recipes_2.csv'

# Guardar CSV
data.to_csv(output_path, index=False)

print("Dataset guardado en:", output_path)
